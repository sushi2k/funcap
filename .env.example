DATABASE_URL="file:./funcap.db"

# Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-32-bytes-of-random-base64"
TOTP_ENCRYPTION_KEY="change-me-32-bytes-of-random-base64"

NODE_ENV="development"

# Solo-local-only escape hatch (req §18.11). NEVER set true in a shared deploy.
# ADMIN_MFA_RELAXED="false"

# Seed inputs — used only by `npm run seed`.
# FIRST_ADMIN_EMAIL="admin@example.com"
# FIRST_ADMIN_DISPLAY_NAME="admin"
# FIRST_ADMIN_PASSWORD="change-this-min-12-chars"

# Never define a NEXT_PUBLIC_* variable that holds a secret.
# Secrets are loaded only by src/server/config and never reach the client.
